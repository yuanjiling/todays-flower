{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Today's Flower",
  "version": "1.0.3",
  "identifier": "com.aia.todaysflower",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Today's Flower",
        "width": 1280,
        "height": 720,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "visible": true,
        "backgroundColor": "#f7f4ea"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Today's Flower",
    "longDescription": "Today's Flower desktop app.",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "both",
        "displayLanguageSelector": true
      }
    }
  }
}

